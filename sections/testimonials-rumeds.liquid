<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--page-width color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
>
  <h2 style="text-align:center; margin-bottom: 2.5rem;">{{ section.settings.heading }}</h2>

  <div class="rumeds-testimonials-grid">
    {% for block in section.blocks %}
      <div class="rumeds-testimonial-card" {{ block.shopify_attributes }}>
        <div class="rumeds-testimonial-stars">⭐⭐⭐⭐⭐</div>
        <p class="rumeds-testimonial-title">{{ block.settings.title }}</p>
        <blockquote class="rumeds-testimonial-quote">{{ block.settings.quote }}</blockquote>
        <cite class="rumeds-testimonial-author">— {{ block.settings.author }}</cite>
      </div>
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .rumeds-testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media screen and (max-width: 749px) {
    .rumeds-testimonials-grid {
      grid-template-columns: 1fr;
    }
  }

  .rumeds-testimonial-card {
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 12px;
    padding: 2rem 1.5rem;
    background: rgba(255,255,255,0.6);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
    transition: box-shadow 0.25s ease, transform 0.25s ease;
  }

  .rumeds-testimonial-card:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,0.1);
    transform: translateY(-3px);
  }

  .rumeds-testimonial-stars {
    font-size: 1rem;
    letter-spacing: 2px;
  }

  .rumeds-testimonial-title {
    font-weight: 700;
    font-size: 1rem;
    margin: 0;
  }

  .rumeds-testimonial-quote {
    font-style: italic;
    margin: 0;
    opacity: 0.85;
    line-height: 1.6;
  }

  .rumeds-testimonial-author {
    font-size: 0.85rem;
    font-weight: 600;
    opacity: 0.7;
    margin-top: auto;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by Medical Professionals"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Review Title",
          "default": "Incredibly Comfortable"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Best scrubs I've ever worn during my 24-hour calls. They literally saved my life."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author Name",
          "default": "Dr. Neha S."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "title": "Incredibly Comfortable",
            "quote": "Best scrubs I've ever worn during my 24-hour calls. They literally saved my life.",
            "author": "Dr. Neha S."
          }
        },
        {
          "type": "review",
          "settings": {
            "title": "Perfect Fit",
            "quote": "The fabric feels premium and the pockets are perfectly placed for rounds.",
            "author": "Dr. Rahul M."
          }
        },
        {
          "type": "review",
          "settings": {
            "title": "Stylish & Functional",
            "quote": "Finally a brand that understands what surgeons actually need in the OR.",
            "author": "Dr. Aisha K."
          }
        }
      ]
    }
  ]
}
{% endschema %}
